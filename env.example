# Copy this file to ".env" and fill in the values.
# The ".env" file is git-ignored and must never be committed.

# ── PayMongo (Dashboard → Developer Tools → API Keys) ────────────
PAYMONGO_SECRET_KEY=sk_test_replace_me
PAYMONGO_PUBLIC_KEY=pk_test_replace_me

# Webhook signing secret (Dashboard → Developer Tools → Webhooks).
PAYMONGO_WEBHOOK_SECRET=whsk_replace_me

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# ── Optional tuning ──────────────────────────────────────────────
PAYMONGO_PAYMENT_METHODS=card,gcash
PAYMONGO_PASS_ON_FEES=false
# APP_BASE_URL=https://your-domain.com
